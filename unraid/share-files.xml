<?xml version="1.0"?>
<Container version="2">
  <Name>share-files</Name>
  <Repository>youruser/share-files:latest</Repository>
  <Registry>https://hub.docker.com/</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/whiterook6/unraid-share/issues</Support>
  <Project>https://github.com/whiterook6/unraid-share</Project>
  <Overview>Manage shareable file links via CLI and serve them over HTTP. Use docker exec to run share commands.</Overview>
  <Category>Tools:Utilities</Category>
  <WebUI>http://[IP]:[PORT:3000]/</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/whiterook6/unraid-share/main/unraid/share-files.xml</TemplateURL>
  <Icon>/plugins/dynamix.docker.manager/images/question.png</Icon>
  <ExtraParams/>
  <PostArgs/>
  <CPUset/>
  <DateInstalled/>
  <DonateText/>
  <DonateLink/>
  <Requires/>
  <Config Name="Appdata" Target="/config" Default="/mnt/user/appdata/share-files" Mode="rw" Description="SQLite database and persistent config" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/share-files</Config>
  <Config Name="WebUI Port" Target="3000" Default="3000" Mode="tcp" Description="HTTP port for serving shared files" Type="Port" Display="always" Required="true" Mask="false">3000</Config>
  <Config Name="SHARE_FILES_ROOT_URL" Target="SHARE_FILES_ROOT_URL" Default="http://[IP]:[PORT:3000]" Mode="" Description="Public URL prefix for share links (use your reverse-proxy URL if applicable)" Type="Variable" Display="always" Required="true" Mask="false">http://[IP]:[PORT:3000]</Config>
  <Config Name="SHARE_FILES_DB" Target="SHARE_FILES_DB" Default="/config/shares.db" Mode="" Description="Path to the SQLite database file" Type="Variable" Display="advanced" Required="true" Mask="false">/config/shares.db</Config>
  <Config Name="PORT" Target="PORT" Default="3000" Mode="" Description="HTTP port the server listens on inside the container (must match the container port mapping target; default 3000)" Type="Variable" Display="advanced" Required="true" Mask="false">3000</Config>
</Container>
