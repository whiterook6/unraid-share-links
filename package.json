{
  "name": "share-files",
  "version": "0.1.0",
  "description": "CLI to manage file share links backed by SQLite",
  "type": "module",
  "bin": {
    "share": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run build:cli && npm run build:server",
    "build:cli": "esbuild src/cli.ts --bundle --platform=node --format=esm --outfile=dist/cli.js --banner:js=\"#!/usr/bin/env node\"",
    "build:server": "esbuild src/server.ts --bundle --platform=node --format=esm --outfile=dist/server.js --packages=external",
    "dev": "npm run dev:cli & npm run dev:server",
    "dev:cli": "esbuild src/cli.ts --bundle --platform=node --format=esm --outfile=dist/cli.js --banner:js=\"#!/usr/bin/env node\" --watch",
    "dev:server": "esbuild src/server.ts --bundle --platform=node --format=esm --outfile=dist/server.js --watch",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "setup": "npm run build && npm link",
    "teardown": "npm unlink -g share-files"
  },
  "engines": {
    "node": ">=24.15.0"
  },
  "devDependencies": {
    "@types/columnify": "^1.5.4",
    "@types/node": "^24.13.0",
    "esbuild": "^0.25.5",
    "prettier": "^3.8.4",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@fastify/helmet": "^13.0.2",
    "columnify": "^1.6.0",
    "commander": "^15.0.0",
    "fastify": "^5.8.5"
  }
}
